{
  "manifest_version": 3,
  "name": "Jira Quick Worklog Sidebar",
  "version": "1.0.0",
  "description": "Recent Jira tickets and quick worklog actions from the browser side panel.",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Jira Quick Worklog Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_page": "settings.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "storage.js",
        "jira_detector.js",
        "jira_actions.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
